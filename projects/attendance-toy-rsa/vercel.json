{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"installCommand": "HUSKY=0 npm install --workspaces --include-workspace-root",
	"buildCommand": "npm run build --workspaces --if-present && npm run build",
	"outputDirectory": "dist",
	"framework": "vite",
	"rewrites": [
		{ "source": "/(.*)", "destination": "/index.html" }
	]
}
